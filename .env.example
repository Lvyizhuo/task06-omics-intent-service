# 组学智能体意图识别服务配置文件
# 复制此文件为 .env 并填入实际值

# ==================== LLM 配置 ====================
# 本地部署的 Qwen3-30B-A3B 模型（OpenAI 兼容接口）
# 注意：本地模型不需要鉴权，但 OpenAI SDK 需要非空值，填入任意占位即可
LLM_API_KEY=not-needed

# LLM 服务地址（本地 Qwen3 部署地址）
LLM_BASE_URL=http://localhost:8000/v1

# LLM 模型名称（与 Qwen3 启动时的 model 参数一致）
LLM_MODEL=qwen3-30b

# ==================== 下游服务地址 ====================
# PlantCAD2 推理服务地址
PLANTCAD2_BASE_URL=http://localhost:8005

# EVO2 转发接口地址（迁移后按实际情况修改）
EVO2_BASE_URL=http://36.137.205.153:8666

# ==================== 服务配置 ====================
# 服务监听地址
HOST=0.0.0.0

# 服务监听端口
PORT=8010

# ==================== 超时配置（秒）====================
# LLM 调用超时
LLM_TIMEOUT=30

# 下游 API 调用超时
API_TIMEOUT=60

# 最大重试次数
MAX_RETRIES=3