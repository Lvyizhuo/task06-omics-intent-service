# 组学智能体意图识别服务配置文件
# 复制此文件为 .env 并填入实际值

# ==================== LLM 配置 ====================
# 阿里云百炼 API Key
LLM_API_KEY=your-api-key-here

# LLM 服务地址（默认使用阿里云百炼）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型名称
LLM_MODEL=qwen-plus-latest

# ==================== 下游服务地址 ====================
# PlantCAD2 推理服务地址
PLANTCAD2_BASE_URL=http://localhost:8005

# EVO2 转发接口地址
EVO2_BASE_URL=http://36.137.205.153:8666

# ==================== 服务配置 ====================
# 服务监听地址
HOST=0.0.0.0

# 服务监听端口
PORT=8010

# ==================== 超时配置（秒）====================
# LLM 调用超时
LLM_TIMEOUT=30

# 下游 API 调用超时
API_TIMEOUT=60

# 最大重试次数
MAX_RETRIES=3
